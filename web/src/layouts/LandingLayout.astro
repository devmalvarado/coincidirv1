---
import '../styles/theme.css';
import '../styles/landing.css';
import ThemeInit from '../components/ThemeInit.astro';
import type { Locale } from '../i18n/types';
import { HOME_PATHS } from '../i18n/paths';

interface Props {
  lang: Locale;
  title?: string;
  description?: string;
}
const {
  lang,
  title = 'Coincidir',
  description = '',
} = Astro.props;

const origin = Astro.site?.origin ?? '';
---
<!doctype html>
<html lang={lang}>
  <head>
    <ThemeInit />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {origin ? (
      <>
        <link rel="alternate" hreflang="es" href={`${origin}${HOME_PATHS.es}`} />
        <link rel="alternate" hreflang="en" href={`${origin}${HOME_PATHS.en}`} />
        <link rel="alternate" hreflang="x-default" href={`${origin}${HOME_PATHS.es}`} />
      </>
    ) : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="coin-page">
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  body.coin-page {
    margin: 0;
  }
</style>
