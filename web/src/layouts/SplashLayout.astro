---
import '../styles/theme.css';
import ThemeInit from '../components/ThemeInit.astro';

interface Props {
  title?: string;
}
const { title = 'Coincidir' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <ThemeInit />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="splash-layout">
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  html,
  body.splash-layout {
    margin: 0;
    height: 100%;
    overflow: hidden;
    background: var(--coin-splash-bg, #0d0d15);
    font-family: 'DM Sans', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
</style>
