---
import type { LandingDict } from '../../i18n/types';

interface Props {
  footer: LandingDict['footer'];
}
const { footer: t } = Astro.props;
const year = new Date().getFullYear();
const copyright = t.copyrightTpl.replace('{year}', String(year));
---
<footer class="coin-footer" id="join">
  <div class="coin-container coin-footer__grid">
    <div>
      <p class="coin-footer__brand">coincidir.social</p>
      <p class="coin-footer__tagline">{t.tagline}</p>
      <div class="coin-footer__links">
        <a href="mailto:hello@coincidir.social">{t.contact}</a>
        <a href="#newsletter">{t.newsletterLink}</a>
        <a href="#" rel="noopener noreferrer">{t.instagram}</a>
        <a href="#" rel="noopener noreferrer">{t.linkedin}</a>
      </div>
      <div class="coin-footer__legal">
        <a href="#">{t.legal}</a>
        <a href="#">{t.privacy}</a>
        <a href="#">{t.terms}</a>
        <span>{copyright}</span>
      </div>
    </div>
    <div class="coin-newsletter" id="newsletter">
      <h3>{t.newsletterTitle}</h3>
      <p>{t.newsletterDesc}</p>
      <form class="coin-newsletter__form" action="#" method="post">
        <label class="visually-hidden" for="newsletter-email">{t.emailLabel}</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          placeholder={t.emailPlaceholder}
          autocomplete="email"
          required
        />
        <button type="submit" class="coin-btn coin-btn--purple">{t.subscribe}</button>
      </form>
    </div>
  </div>
</footer>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
