---
import type { LandingDict } from '../../i18n/types';

interface Props {
  pillars: LandingDict['pillars'];
}
const { pillars: t } = Astro.props;
---
<section class="coin-section coin-section--light coin-pillars" aria-labelledby="pillars-heading">
  <div class="coin-container">
    <h2 class="coin-section__title" id="pillars-heading">{t.title}</h2>
    <div class="coin-pillars__grid">
      {t.items.map((p) => (
        <article class="coin-pillar">
          <h3>{p.title}</h3>
          <p>{p.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
