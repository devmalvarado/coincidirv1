---
interface Props {
  src?: string;
}
const { src = '/lottie/hero.lottie' } = Astro.props;
---
<div class="splash-lottie" data-splash-lottie data-lottie-src={src}>
  <canvas class="splash-lottie__canvas" aria-hidden="true"></canvas>
</div>
<script>
  import { DotLottie } from '@lottiefiles/dotlottie-web';

  const root = document.querySelector('[data-splash-lottie]');
  const url = root?.getAttribute('data-lottie-src');
  const canvas = root?.querySelector('.splash-lottie__canvas');
  if (url && canvas instanceof HTMLCanvasElement) {
    new DotLottie({
      canvas,
      src: url,
      loop: false,
      autoplay: true,
      layout: { fit: 'cover' },
      renderConfig: { autoResize: true },
    });
  }
</script>
<style>
  .splash-lottie {
    position: fixed;
    inset: 0;
    z-index: 0;
    display: block;
  }
  .splash-lottie__canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
