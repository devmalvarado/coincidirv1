---
// Sin lógica de servidor: script inline en <head>
---
<script is:inline>
  (function () {
    try {
      var k = 'coincidir-theme';
      var s = localStorage.getItem(k);
      var t =
        s === 'light' || s === 'dark'
          ? s
          : window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
      document.documentElement.setAttribute('data-theme', t);
    } catch (e) {}
  })();
</script>
