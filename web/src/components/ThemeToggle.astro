---
interface Props {
  themeAria: string;
  themeAuto: string;
  themeLight: string;
  themeDark: string;
}
const { themeAria, themeAuto, themeLight, themeDark } = Astro.props;
---
<div class="coin-theme" role="group" aria-label={themeAria}>
  <button
    type="button"
    class="coin-theme__btn"
    data-theme-pref="system"
    aria-pressed="false"
    title={themeAuto}
  >
    <span class="coin-theme__icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <rect x="2" y="3" width="20" height="14" rx="2" />
        <path d="M8 21h8M12 17v4" />
      </svg>
    </span>
    <span class="coin-theme__sr">{themeAuto}</span>
  </button>
  <button
    type="button"
    class="coin-theme__btn"
    data-theme-pref="light"
    aria-pressed="false"
    title={themeLight}
  >
    <span class="coin-theme__icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
      </svg>
    </span>
    <span class="coin-theme__sr">{themeLight}</span>
  </button>
  <button
    type="button"
    class="coin-theme__btn"
    data-theme-pref="dark"
    aria-pressed="false"
    title={themeDark}
  >
    <span class="coin-theme__icon" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
    </span>
    <span class="coin-theme__sr">{themeDark}</span>
  </button>
</div>

<script is:inline>
  (function () {
    var KEY = 'coincidir-theme';

    function resolved() {
      var s = localStorage.getItem(KEY);
      if (s === 'light' || s === 'dark') return s;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function preference() {
      var s = localStorage.getItem(KEY);
      return s === 'light' || s === 'dark' ? s : 'system';
    }

    function applyTheme() {
      document.documentElement.setAttribute('data-theme', resolved());
    }

    function syncButtons() {
      var pref = preference();
      document.querySelectorAll('[data-theme-pref]').forEach(function (btn) {
        var p = btn.getAttribute('data-theme-pref');
        var active = p === pref;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    function applyAll() {
      applyTheme();
      syncButtons();
    }

    document.addEventListener('DOMContentLoaded', function () {
      applyAll();
      window
        .matchMedia('(prefers-color-scheme: dark)')
        .addEventListener('change', function () {
          if (!localStorage.getItem(KEY)) applyAll();
        });
      document.querySelectorAll('[data-theme-pref]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var p = btn.getAttribute('data-theme-pref');
          if (p === 'system') localStorage.removeItem(KEY);
          else localStorage.setItem(KEY, p);
          applyAll();
        });
      });
    });
  })();
</script>

<style>
  .coin-theme {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    border-radius: 10px;
    background: rgba(128, 128, 128, 0.12);
    border: 1px solid rgba(128, 128, 128, 0.2);
  }

  .coin-theme__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 28px;
    padding: 0;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--coin-text-muted);
    cursor: pointer;
    transition:
      background 0.15s,
      color 0.15s;
  }

  .coin-theme__btn:hover {
    color: var(--coin-text-on-dark);
    background: rgba(128, 128, 128, 0.12);
  }

  .coin-theme__btn.is-active {
    color: var(--coin-text-on-dark);
    background: rgba(139, 92, 246, 0.2);
    box-shadow: 0 0 0 1px rgba(139, 92, 246, 0.35);
  }

  .coin-theme__btn:focus-visible {
    outline: 2px solid var(--coin-purple);
    outline-offset: 2px;
  }

  .coin-theme__icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .coin-theme__sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .coin-theme__btn {
    position: relative;
  }
</style>
